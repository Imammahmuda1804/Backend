# Server
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/wisata_db

# Seed admin
SEED_ADMIN_EMAIL=admin@wisata.com
SEED_ADMIN_NAME=Admin RANAHINSIGHT
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_RESET_PASSWORD=false

# JWT
# Generate secure secrets using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Or use: openssl rand -hex 64
JWT_SECRET=your-jwt-secret-key-change-this-in-production
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-change-this-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Google OAuth
# Web client ID wajib untuk login Google web dan mobile serverClientId.
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# Opsional: daftar client ID yang diterima backend, pisahkan koma.
GOOGLE_CLIENT_IDS=your-google-web-client-id.apps.googleusercontent.com,your-android-client-id.apps.googleusercontent.com

# NLP Service (FastAPI)
NLP_SERVICE_URL=http://localhost:8001

# Apify
# Backend membaca APIFY_API_TOKEN. APIFY_TOKEN tetap didukung sebagai fallback.
APIFY_API_TOKEN=your-apify-token-here
APIFY_TOKEN=your-apify-token-here

# Redis
# Bisa memakai REDIS_URL langsung untuk Upstash/Redis Cloud.
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
# Isi jika memakai managed Redis seperti Upstash/Redis Cloud.
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=false

# Supabase Storage
# Jika tiga env ini diisi, upload gambar destinasi/avatar disimpan ke Supabase Storage.
# Jika kosong, backend fallback ke uploads lokal untuk development.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=ranahinsight-images

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ============================================
// ENUM
// ============================================

enum Role {
  ADMIN
  USER
}

// ============================================
// 1. USER
// ============================================

model User {
  id             Int      @id @default(autoincrement())
  name           String
  email          String   @unique
  password       String
  role           Role     @default(USER)
  status         String   @default("active")
  profilePicture String?  @map("profile_picture")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  favorites    Favorite[]
  routes       Route[]
  savedRoutes  SavedRoute[]
  searchLogs   SearchLog[]
  userReviews  UserReview[]
  scrapingJobs ScrapingJob[]
  nlpProcessingRuns NlpProcessingRun[]

  @@map("users")
}

// ============================================
// 2. DESTINATION
// ============================================

model Destination {
  id          Int     @id @default(autoincrement())
  name        String
  slug        String  @unique
  description String?

  city     String
  province String
  category String @default("alam")

  latitude  Float?
  longitude Float?

  googleMapsUrl    String? @map("google_maps_url")
  googlePlaceId    String? @map("google_place_id")
  googleRating     Float?  @map("google_rating")
  googleReviewCount Int?   @map("google_review_count")

  userRating      Float? @map("user_rating")
  userReviewCount Int?   @map("user_review_count")

  youtubeUrl   String? @map("youtube_url")
  thumbnailUrl String? @map("thumbnail_url")

  // pgvector embedding — Prisma tidak support native, gunakan raw SQL
  embedding Unsupported("vector(384)")?

  positiveRatio       Float? @map("positive_ratio")
  recommendationScore Float? @map("recommendation_score")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  images            DestinationImage[]
  reviews           Review[]
  sentimentTrends   SentimentTrend[]
  favorites         Favorite[]
  userReviews       UserReview[]
  destinationTopics DestinationTopic[]
  scrapingJobs      ScrapingJob[]
  scrapingHistories ScrapingHistory[]
  routeStops        RouteStop[]
  nlpProcessingRuns NlpProcessingRun[]

  @@index([slug])
  @@index([city])
  @@index([category])
  @@index([province])
  @@index([recommendationScore])
  @@index([deletedAt])
  @@map("destinations")
}

// ============================================
// 3. DESTINATION IMAGE
// ============================================

model DestinationImage {
  id            Int      @id @default(autoincrement())
  destinationId Int      @map("destination_id")
  imageUrl      String   @map("image_url")
  createdAt     DateTime @default(now()) @map("created_at")

  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@index([destinationId])
  @@map("destination_images")
}

// ============================================
// 4. REVIEW (scraped from Google Maps)
// ============================================

model Review {
  id            Int       @id @default(autoincrement())
  destinationId Int       @map("destination_id")
  reviewerName  String    @map("reviewer_name")
  reviewText    String?   @map("review_text")
  cleanedText   String?   @map("cleaned_text")
  rating        Int?
  reviewDate    DateTime? @map("review_date")
  source        String?   @default("google_maps")
  reviewHash    String?   @map("review_hash")
  likesCount    Int?      @map("likes_count")
  ownerReply    String?   @map("owner_reply")
  sentiment     String?
  sentimentConfidence Float? @map("sentiment_confidence")
  topicId       Int?      @map("topic_id")
  scrapingJobId Int?      @map("scraping_job_id")
  createdAt     DateTime  @default(now()) @map("created_at")

  destination     Destination      @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  topic           Topic?           @relation(fields: [topicId], references: [id])
  scrapingJob     ScrapingJob?     @relation(fields: [scrapingJobId], references: [id])
  reviewEmbedding ReviewEmbedding?

  @@index([destinationId])
  @@index([sentiment])
  @@index([topicId])
  @@index([createdAt])
  @@index([scrapingJobId])
  @@unique([destinationId, source, reviewHash])
  @@map("reviews")
}

model NlpProcessingRun {
  id                Int       @id @default(autoincrement())
  destinationId     Int       @map("destination_id")
  adminId           Int?      @map("admin_id")
  fileName          String    @map("file_name")
  fileHash          String    @map("file_hash")
  mode              String    @default("skip_existing")
  status            String    @default("processing")
  totalRows         Int       @default(0) @map("total_rows")
  insertedReviews   Int       @default(0) @map("inserted_reviews")
  skippedDuplicates Int       @default(0) @map("skipped_duplicates")
  processedReviews  Int       @default(0) @map("processed_reviews")
  errorMessage      String?   @map("error_message")
  startedAt         DateTime  @default(now()) @map("started_at")
  finishedAt        DateTime? @map("finished_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  admin       User?       @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([destinationId])
  @@index([adminId])
  @@index([fileHash])
  @@index([status])
  @@index([startedAt])
  @@map("nlp_processing_runs")
}

// ============================================
// 5. REVIEW EMBEDDING (pgvector)
// ============================================

model ReviewEmbedding {
  id       Int                        @id @default(autoincrement())
  reviewId Int                        @unique @map("review_id")
  embedding Unsupported("vector(384)")?

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("review_embeddings")
}

// ============================================
// 6. TOPIC (from BERTopic)
// ============================================

model Topic {
  id              Int      @id @default(autoincrement())
  topicName       String   @map("topic_name")
  keywords        Json?
  groupId         Int?     @map("group_id")
  labelType       String   @default("fine") @map("label_type")
  isSearchVisible Boolean  @default(true) @map("is_search_visible")
  isDetailVisible Boolean  @default(true) @map("is_detail_visible")
  createdAt       DateTime @default(now()) @map("created_at")

  group             TopicGroup?        @relation(fields: [groupId], references: [id], onDelete: SetNull)
  reviews           Review[]
  destinationTopics DestinationTopic[]

  @@index([groupId])
  @@index([isSearchVisible])
  @@map("topics")
}

model TopicGroup {
  id           Int      @id @default(autoincrement())
  groupName    String   @map("group_name")
  description  String?
  keywords     Json?
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  topics Topic[]

  @@map("topic_groups")
}

// ============================================
// 7. DESTINATION TOPIC (many-to-many pivot)
// ============================================

model DestinationTopic {
  id            Int @id @default(autoincrement())
  destinationId Int @map("destination_id")
  topicId       Int @map("topic_id")
  totalReviews  Int @default(0) @map("total_reviews")

  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  topic       Topic       @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([destinationId, topicId])
  @@map("destination_topics")
}

// ============================================
// 8. SENTIMENT TREND (time-series data)
// ============================================

model SentimentTrend {
  id            Int      @id @default(autoincrement())
  destinationId Int      @map("destination_id")
  date          DateTime
  positiveCount Int      @default(0) @map("positive_count")
  negativeCount Int      @default(0) @map("negative_count")
  neutralCount  Int      @default(0) @map("neutral_count")

  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@unique([destinationId, date])
  @@index([destinationId])
  @@index([date])
  @@map("sentiment_trends")
}

// ============================================
// 9. FAVORITE (user wishlist)
// ============================================

model Favorite {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  destinationId Int      @map("destination_id")
  createdAt     DateTime @default(now()) @map("created_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@unique([userId, destinationId])
  @@index([userId])
  @@map("favorites")
}

// ============================================
// 10. SEARCH LOG
// ============================================

model SearchLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  keyword   String
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("search_logs")
}

// ============================================
// 11. USER REVIEW (rating & review by user)
// ============================================

model UserReview {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  destinationId Int      @map("destination_id")
  rating        Int
  reviewText    String?  @map("review_text")
  createdAt     DateTime @default(now()) @map("created_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([destinationId])
  @@map("user_reviews")
}

// ============================================
// 12. SCRAPING JOB
// ============================================

model ScrapingJob {
  id            Int       @id @default(autoincrement())
  destinationId Int       @map("destination_id")
  status        String    @default("pending")
  source        String    @default("google_maps")
  totalReviews  Int?      @map("total_reviews")
  startedAt     DateTime? @map("started_at")
  finishedAt    DateTime? @map("finished_at")
  errorMessage  String?   @map("error_message")
  createdBy     Int?      @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")

  destination       Destination       @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  createdByUser     User?             @relation(fields: [createdBy], references: [id])
  scrapingHistories ScrapingHistory[]
  reviews           Review[]

  @@index([destinationId])
  @@index([status])
  @@index([createdAt])
  @@map("scraping_jobs")
}

// ============================================
// 13. SCRAPING HISTORY
// ============================================

model ScrapingHistory {
  id            Int      @id @default(autoincrement())
  destinationId Int      @map("destination_id")
  jobId         Int      @map("job_id")
  totalReviews  Int?     @map("total_reviews")
  starsFilter   Json?    @map("stars_filter")
  hasText       Boolean? @map("has_text")
  sort          String?
  createdAt     DateTime @default(now()) @map("created_at")

  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  job         ScrapingJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([destinationId])
  @@index([jobId])
  @@map("scraping_history")
}

model Route {
  id                       Int      @id @default(autoincrement())
  title                    String
  description              String?
  createdByUserId          Int?     @map("created_by_user_id")
  isAdminCurated           Boolean  @default(false) @map("is_admin_curated")
  visibility               String   @default("private")
  shareSlug                String   @unique @map("share_slug")
  city                     String?
  totalDistanceKm          Float?   @map("total_distance_km")
  estimatedDurationMinutes Int?     @map("estimated_duration_minutes")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  createdBy   User?        @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  stops       RouteStop[]
  savedRoutes SavedRoute[]

  @@index([createdByUserId])
  @@index([visibility])
  @@index([isAdminCurated])
  @@index([city])
  @@map("routes")
}

model RouteStop {
  id                     Int    @id @default(autoincrement())
  routeId                Int    @map("route_id")
  destinationId          Int    @map("destination_id")
  stopOrder              Int    @map("stop_order")
  distanceFromPreviousKm Float? @map("distance_from_previous_km")
  distanceToNextKm       Float? @map("distance_to_next_km")
  note                   String?
  estimatedVisitMinutes  Int?   @map("estimated_visit_minutes")

  route       Route       @relation(fields: [routeId], references: [id], onDelete: Cascade)
  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  progress    SavedRouteProgress[]

  @@unique([routeId, destinationId])
  @@index([routeId])
  @@index([destinationId])
  @@index([stopOrder])
  @@map("route_stops")
}

model SavedRoute {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  routeId   Int      @map("route_id")
  createdAt DateTime @default(now()) @map("created_at")

  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  route    Route                @relation(fields: [routeId], references: [id], onDelete: Cascade)
  progress SavedRouteProgress[]

  @@unique([userId, routeId])
  @@index([userId])
  @@index([routeId])
  @@map("saved_routes")
}

model SavedRouteProgress {
  id           Int       @id @default(autoincrement())
  savedRouteId Int       @map("saved_route_id")
  routeStopId  Int       @map("route_stop_id")
  status       String    @default("pending")
  note         String?
  visitedAt    DateTime? @map("visited_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  savedRoute SavedRoute @relation(fields: [savedRouteId], references: [id], onDelete: Cascade)
  routeStop  RouteStop  @relation(fields: [routeStopId], references: [id], onDelete: Cascade)

  @@unique([savedRouteId, routeStopId])
  @@index([savedRouteId])
  @@index([routeStopId])
  @@map("saved_route_progress")
}
